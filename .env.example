# ====================================
# Environment Variables Reference
# ====================================
# Copy this file to .env and fill in
# cp .env.example .env
# ====================================

# GitHub Actions (automatically provided, no manual setup needed)
# GITHUB_TOKEN: Automatically injected by GitHub Actions

# Google Tag Manager (optional)
# 到 https://tagmanager.google.com/ 建立容器後取得 ID
# GTM_CONTAINER_ID=GTM-XXXXXXX

# Google AdSense (optional)
# 到 https://adsense.google.com/ 取得發布商 ID
# ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXX

# Comment System (if using Gitalk / Utterances, optional)
# GITALK_CLIENT_ID=
# GITALK_CLIENT_SECRET=

# Algolia Search (optional)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=
