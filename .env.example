# ====================================
# Environment Variables Reference
# ====================================
# Copy this file to .env and fill in
# cp .env.example .env
# ====================================

# GitHub Actions (automatically provided, no manual setup needed)
# GITHUB_TOKEN: Automatically injected by GitHub Actions

# Google Analytics (optional)
# GA_TRACKING_ID=G-XXXXXXXXXX

# Comment System (if using Gitalk / Utterances, optional)
# GITALK_CLIENT_ID=
# GITALK_CLIENT_SECRET=

# Algolia Search (optional)
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_INDEX_NAME=
